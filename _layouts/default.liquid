<!doctype html>
<html lang="{{ site.lang }}">
  <!-- Head -->
  <head>
    {% if page.redirect %}
      {% if page.redirect == true %}
        {% assign redirect = site.baseurl | append: '/' %}
      {% elsif page.redirect contains '://' %}
        {% assign redirect = page.redirect %}
      {% else %}
        {% assign redirect = page.redirect | relative_url %}
      {% endif %}
      <meta http-equiv="refresh" content="3; url={{ redirect }}">
    {% endif %}
    {% include head.liquid %}
  </head>

  <!-- Body -->
  <body class="{% if site.navbar_fixed %}fixed-top-nav{% endif %} {% unless site.footer_fixed %}sticky-bottom-footer{% endunless %}">
    <!-- Header -->
    {% include header.liquid %}

    <!-- Content -->
    <div class="container mt-5" role="main">
      {% if page.toc and page.toc.sidebar %}
        {% if page.toc.sidebar == 'right' %}
          <div class="row">
            <!-- main content area -->
            <div class="col-sm-9">{{ content }}</div>
            <!-- sidebar, which will move to the top on a small screen -->
            <div class="col-sm-3">
              <nav id="toc-sidebar" class="sticky-top"></nav>
            </div>
          </div>
        {% else %}
          <div class="row">
            <!-- sidebar, which will move to the top on a small screen -->
            <div class="col-sm-3">
              <nav id="toc-sidebar" class="sticky-top"></nav>
            </div>
            <!-- main content area -->
            <div class="col-sm-9">{{ content }}</div>
          </div>
        {% endif %}
      {% else %}
        {{ content }}
      {% endif %}
    </div>

    <!-- Footer -->
    {% include footer.liquid %}

    <!-- JavaScripts -->
    {% include scripts.liquid %}

    <script>
      // 1. Nếu bạn chủ động vào trang stats, đóng dấu bạn là Chủ nhà
      if (window.location.pathname.includes('my-secret-stats')) {
        localStorage.setItem('site_owner', 'true');
      }

      // 2. Nếu là Chủ nhà đang F5 hoặc xem trang stats, đóng băng không cho gửi lệnh đếm lên server twb.nz
      if (localStorage.getItem('site_owner') === 'true' && window.location.pathname.includes('my-secret-stats')) {
        window.stop(); // Dừng lệnh tải trang ngầm để ngắt bộ đếm tự động của badge
        
        // Tạo một vùng hiển thị ảnh tĩnh an toàn để bạn vẫn nhìn thấy con số thực tế mà không bị tăng ảo
        document.body.innerHTML = document.body.innerHTML.replace(
          'src="https://twb.nz/api/v1/badge?url=https://nguyen-an13.github.io&amp;title=Views&amp;color=blue"',
          'src="https://twb.nz/api/v1/badge?url=https://nguyen-an13.github.io&title=Views&color=blue&admin=true"'
        );
      }
    </script>
  </body>
</html>
